      "stem": [],
      "parts": [
        {
          "label": "(a)",
          "marks": 4,
          "content": [
            {
              "type": "text",
              "content": "Find the first 4 terms, in ascending powers of x, of the binomial expansion of"
            },
            {
              "type": "newline"
            },
            {
              "type": "text",
              "content": "$$\\left(2 - \\frac{kx}{8}\\right)^4$$"
            },
            {
              "type": "newline"
            },
            {
              "type": "text",
              "content": "where k is a non‑zero constant. Give each term in simplest form."
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "expression"
          }
        },
        {
          "label": "(b)",
          "marks": 3,
          "content": [
            {
              "type": "text",
              "content": "f(x) = $(5 - 3x) \\left(2 - \\frac{kx}{8}\\right)^4$"
            },
            {
              "type": "newline"
            },
            {
              "type": "text",
              "content": "In the expansion of f(x), the constant term is 3 times the coefficient of x."
            },
            {
              "type": "newline"
            },
            {
              "type": "text",
              "content": "Find the value of k."
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "number"
          }
        }
      ],
      "answer": null,
      "meta": {}
    },
