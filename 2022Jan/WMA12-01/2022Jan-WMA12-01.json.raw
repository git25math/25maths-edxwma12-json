      "stem": [
        {
          "type": "text",
          "content": "The table below shows corresponding values of x and y for"
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "$$y = \frac{25}{x} - x$$"
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "The values of y are given to 3 decimal places."
        },
        {
          "type": "table",
          "content": "\\begin{tabular}{|c|c|c|c|c|c|}\n\\hline\nx & 5 & 5.5 & 6 & 6.5 & 7 \\\\\n\\hline\ny & 6.792 & 6.298 & 5.858 & 5.466 & 5.113 \\\\\n\\hline\n\\end{tabular}"
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "Using the trapezium rule with all the values of y in the given table,"
        }
      ],
      "parts": [
        {
          "label": "(a)",
          "marks": 3,
          "content": [
            {
              "type": "text",
              "content": "obtain an estimate for"
            },
            {
              "type": "newline"
            },
            {
              "type": "text",
              "content": "$$\\int_5^7 \frac{25}{x} - x \, \\mathrm{d}x$$"
            },
            {
              "type": "newline"
            },
            {
              "type": "text",
              "content": "giving your answer to 2 decimal places."
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "number",
            "decimalPlaces": 2
          }
        },
        {
          "label": "(b)",
          "marks": 4,
          "content": [
            {
              "type": "text",
              "content": "Using your answer to part (a) and making your method clear, estimate"
            }
          ],
          "subparts": [
            {
              "label": "(i)",
              "marks": 2,
              "content": [
                {
                  "type": "text",
                  "content": "$$\\int_5^7 \frac{26}{x} - x \, \\mathrm{d}x$$"
                },
                {
                  "type": "space",
                  "height": "1cm"
                }
              ],
              "answer": {
                "type": "number",
                "decimalPlaces": 2
              }
            },
            {
              "label": "(ii)",
              "marks": 2,
              "content": [
                {
                  "type": "text",
                  "content": "$$\\int_5^7 \\left( \\frac{25}{x} - x \\right) + 3 \, \\mathrm{d}x$$"
                },
                {
                  "type": "space",
                  "height": "1cm"
                }
              ],
              "answer": {
                "type": "number",
                "decimalPlaces": 2
              }
            }
          ],
          "answer": null
        }
      ],
      "answer": null,
      "meta": {}
