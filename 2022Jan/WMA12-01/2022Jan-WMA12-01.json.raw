    {
      "qnum": 8,
      "marks": 9,
      "stem": [
        {
          "type": "text",
          "content": "A metal post is repeatedly hit in order to drive it into the ground."
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "Given that"
        },
        {
          "type": "list",
          "style": "bullet",
          "items": [
            "on the 1st hit, the post is driven 100 mm into the ground",
            "on the 2nd hit, the post is driven an additional 98 mm into the ground",
            "on the 3rd hit, the post is driven an additional 96 mm into the ground",
            "the additional distances the post travels on each subsequent hit form an arithmetic sequence"
          ]
        }
      ],
      "parts": [
        {
          "label": "(a)",
          "marks": 1,
          "content": [
            {
              "type": "text",
              "content": "show that the post is driven an additional 62 mm into the ground with the 20th hit."
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "none"
          }
        },
        {
          "label": "(b)",
          "marks": 2,
          "content": [
            {
              "type": "text",
              "content": "Find the total distance that the post has been driven into the ground after 20 hits."
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "number",
            "suffix": "mm"
          }
        },
        {
          "label": "(c)",
          "marks": 2,
          "content": [
            {
              "type": "text",
              "content": "Given that for each subsequent hit after the 20th hit"
            },
            {
              "type": "list",
              "style": "bullet",
              "items": [
                "the additional distances the post travels form a geometric sequence with common ratio r",
                "on the 22nd hit, the post is driven an additional 60 mm into the ground"
              ]
            },
            {
              "type": "text",
              "content": "find the value of r, giving your answer to 3 decimal places."
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "number",
            "decimalPlaces": 3
          }
        },
        {
          "label": "(d)",
          "marks": 4,
          "content": [
            {
              "type": "text",
              "content": "After a total of N hits, the post will have been driven more than 3 m into the ground."
            },
            {
              "type": "newline"
            },
            {
              "type": "text",
              "content": "Find, showing all steps in your working, the smallest possible value of N."
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "number"
          }
        }
      ],
      "answer": null,
      "meta": {}
