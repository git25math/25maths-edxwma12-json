    {
      "qnum": 5,
      "marks": 8,
      "stem": [
        {
          "type": "text",
          "content": "f(x) = $3x^3 + Ax^2 + Bx - 10$"
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "where A and B are integers."
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "Given that"
        },
        {
          "type": "list",
          "style": "bullet",
          "items": [
            "when f(x) is divided by (x – 1) the remainder is k",
            "when f(x) is divided by (x + 1) the remainder is –10k",
            "k is a constant"
          ]
        }
      ],
      "parts": [
        {
          "label": "(a)",
          "marks": 3,
          "content": [
            {
              "type": "text",
              "content": "show that"
            },
            {
              "type": "newline"
            },
            {
              "type": "text",
              "content": "$$11A + 9B = 83$$"
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "none"
          }
        },
        {
          "label": "(b)",
          "marks": 3,
          "content": [
            {
              "type": "text",
              "content": "Given also that (3x – 2) is a factor of f(x),"
            },
            {
              "type": "newline"
            },
            {
              "type": "text",
              "content": "find the value of A and the value of B."
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "structured",
            "answerBlocks": [
              {
                "type": "number",
                "prefix": "A = "
              },
              {
                "type": "number",
                "prefix": "B = "
              }
            ]
          }
        },
        {
          "label": "(c)",
          "marks": 2,
          "content": [
            {
              "type": "text",
              "content": "Hence find the quadratic expression g(x) such that"
            },
            {
              "type": "newline"
            },
            {
              "type": "text",
              "content": "$$f(x) = (3x - 2)\\,\\mathrm{g}(x)$$"
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "expression"
          }
        }
      ],
      "answer": null,
      "meta": {}
