          "content": [
            {
              "type": "table",
              "content": "\\begin{tabular}{|c|c|c|c|c|c|c|} \\hline x & –4 & –1.5 & 1 & 3.5 & 6 & 8.5 \\\\ \\hline y & 13 & 6.280 & 4.577 & 4.146 & 4.037 & 4.009 \\\\ \\hline \\end{tabular}"
