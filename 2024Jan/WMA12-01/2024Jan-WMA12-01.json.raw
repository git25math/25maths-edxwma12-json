            },
            {
              "type": "newline"
            },
            {
              "type": "text",
              "content": "$$\\int_{1.5}^{8.5} \\left(\\frac{3}{x} + \\frac{4}{x^2} + \\frac{1}{2}\\right) \\mathrm{d}x$$"
