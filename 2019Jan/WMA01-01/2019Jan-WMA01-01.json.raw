      "stem": [
        {
          "type": "text",
          "content": "Karen is going to raise money for a charity."
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "She aims to cycle a total distance of 1000 km over a number of days."
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "On day one she cycles 25 km."
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "She increases the distance that she cycles each day by 10% of the distance cycled on the previous day, until she reaches the total distance of 1000 km."
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "She reaches the total distance of 1000 km on day N, where N is a positive integer."
        }
      ],
      "parts": [
        {
          "label": "(a)",
          "marks": 4,
          "content": [
            {
              "type": "text",
              "content": "Find the value of N."
