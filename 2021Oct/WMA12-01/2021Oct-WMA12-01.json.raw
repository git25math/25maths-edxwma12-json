      "stem": [
        {
          "type": "text",
          "content": "The first three terms, in ascending powers of x, of the binomial expansion of $(1 + kx)^{16}$ are"
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "$1, -4x$ and $px^2$"
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "where k and p are constants."
        }
      ],
      "parts": [
        {
          "label": "(a)",
          "marks": 3,
          "content": [
            {
              "type": "text",
              "content": "Find, in simplest form,"
            }
          ],
          "subparts": [
            {
              "label": "(i)",
              "marks": null,
              "content": [
                {
                  "type": "text",
                  "content": "the value of k"
                },
                {
                  "type": "space",
                  "height": "1cm"
                }
              ],
              "answer": {
                "type": "number"
              }
            },
            {
              "label": "(ii)",
              "marks": null,
              "content": [
                {
                  "type": "text",
                  "content": "the value of p"
                },
                {
                  "type": "space",
                  "height": "1cm"
                }
              ],
              "answer": {
                "type": "number"
              }
            }
          ],
          "answer": null
        },
        {
          "label": "(b)",
          "marks": 3,
          "content": [
            {
              "type": "text",
              "content": "Using the value of k found in part (a),"
            },
            {
              "type": "newline"
            },
            {
              "type": "text",
              "content": "find the term in $x^2$ in the expansion of $g(x)$, where $g(x) = 2 + \\frac{1}{16}(1+kx)^{16}$."
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "expression"
          }
        }
      ],
      "answer": null,
      "meta": {}
    },
    {
