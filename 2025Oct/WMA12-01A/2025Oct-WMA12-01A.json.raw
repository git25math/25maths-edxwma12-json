          "label": "(a)",
          "marks": 2,
          "content": [
            {
              "type": "text",
              "content": "Write down expressions for $u_2$ and $u_3$ in terms of $k$."
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "expression"
          }
        },
        {
          "label": "(b)",
          "marks": 3,
          "stem": [
            {
              "type": "text",
              "content": "Given that $u_3 = 6$"
            }
          ],
          "content": [
            {
              "type": "text",
              "content": "find the possible values of $k$."
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "expression"
          }
        }
      ],
      "answer": null,
