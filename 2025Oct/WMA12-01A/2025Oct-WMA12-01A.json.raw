        {
          "type": "table",
          "content": "\\begin{tabular}{|c|c|c|c|c|}\n\\hline\nx & 2 & 5 & 8 & 11 \\\\\n\\hline\ny & 8.485 & 2.502 & 1.524 & 1.100 \\\\\n\\hline\n\\end{tabular}"
