    {
      "qnum": 8,
      "marks": 7,
      "stem": [
        {
          "type": "text",
          "content": "In a large theatre there are n rows of seats, where n is a constant."
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "The number of seats in the first row is a, where a is a constant."
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "In each subsequent row there are 4 more seats than in the previous row so that"
        },
        {
          "type": "list",
          "style": "bullet",
          "items": [
            "in the 2nd row there are $(a + 4)$ seats",
            "in the 3rd row there are $(a + 8)$ seats",
            "the number of seats in each row form an arithmetic sequence"
          ]
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "Given that the total number of seats in the first 10 rows is 360"
        },
        {
          "type": "newline"
        }
      ],
      "parts": [
        {
          "label": "(a)",
          "marks": 2,
          "content": [
            {
              "type": "text",
              "content": "find the value of a."
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "number"
          }
        },
        {
          "label": "(b)",
          "marks": 2,
          "content": [
            {
              "type": "text",
              "content": "Given also that the total number of seats in the n rows is 2146"
            },
            {
              "type": "newline"
            },
            {
              "type": "text",
              "content": "show that"
            },
            {
              "type": "newline"
            },
            {
              "type": "text",
              "content": "$n^2 + 8n - 1073 = 0$"
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "none"
          }
        },
        {
          "label": "(c)",
          "marks": 3,
          "content": [
            {
              "type": "text",
              "content": "Hence"
            },
            {
              "type": "newline"
            }
          ],
          "subparts": [
            {
              "label": "(i)",
              "marks": 1,
              "content": [
                {
                  "type": "text",
                  "content": "state the number of rows of seats in the theatre,"
                },
                {
                  "type": "space",
                  "height": "1cm"
                }
              ],
              "answer": {
                "type": "number"
              }
            },
            {
              "label": "(ii)",
              "marks": 2,
              "content": [
                {
                  "type": "text",
                  "content": "find the maximum number of seats in any one row."
                },
                {
                  "type": "space",
                  "height": "1cm"
                }
              ],
              "answer": {
