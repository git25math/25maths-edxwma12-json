    {
      "qnum": 1,
      "marks": 3,
      "stem": [
        {
          "type": "text",
          "content": "Given that a, b and c are integers greater than 0 such that"
        },
        {
          "type": "list",
          "style": "bullet",
          "items": [
            "$c = 3a + 1$",
            "$a + b + c = 15$"
          ]
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "prove, by exhaustion, that the product abc is always a multiple of 4"
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "You may use the table below to illustrate your answer."
        },
        {
          "type": "newline"
        },
        {
          "type": "table",
          "content": "\\begin{tabular}{|l|l|l|l|}\n\\hline\na & b & c & abc \\\\\n\\hline\n\\end{tabular}"
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "You may not need to use all rows of this table."
        },
        {
          "type": "space",
          "height": "1cm"
        }
      ],
      "parts": [],
      "answer": {
        "type": "none"
      },
      "meta": {}
    },
    {
      "qnum": 2,
      "marks": 5,
      "stem": [
        {
          "type": "text",
          "content": "A sequence $u_1, u_2, u_3, \dots$ is defined by"
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "$u_1 = 3$"
        },
        {
          "type": "newline"
        },
        {
          "type": "text",
          "content": "$u_{n+1} = 2 - \\frac{4}{u_n}$"
        },
        {
          "type": "newline"
        }
      ],
      "parts": [
        {
          "label": "(a)",
          "marks": 3,
          "content": [
            {
              "type": "text",
              "content": "Find the value of $u_2$, the value of $u_3$ and the value of $u_4$"
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "expression"
          }
        },
        {
          "label": "(b)",
          "marks": 2,
          "content": [
            {
              "type": "text",
              "content": "Find the value of $\\sum_{r=1}^{100} u_r$"
            },
            {
              "type": "space",
              "height": "1cm"
            }
          ],
          "answer": {
            "type": "number"
          }
        }
      ],
      "answer": null,
      "meta": {}
    },
